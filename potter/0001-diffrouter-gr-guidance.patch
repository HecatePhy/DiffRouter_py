+// DiffRouter GR guidance: load per-net route guide (tile set). File format, one
+// line per net:  <net_name> <ntiles> row,col row,col ...
+// DiffRouter uses (row, col); Potter tile X<-col, Y<-row (verify orientation).
+void Database::loadGuide() {
+    if (guideFile.empty()) return;
+    std::unordered_map<std::string, int> nameToNetId;
+    nameToNetId.reserve(netNames.size() * 2);
+    for (size_t i = 0; i < netNames.size(); i++) nameToNetId[netNames[i]] = (int)i;
+    netGuideTiles.assign(nets.size(), std::unordered_set<uint32_t>());
+    std::ifstream in(guideFile);
+    if (!in.good()) {
+        log() << "WARNING: could not open guide file " << guideFile << std::endl;
+        return;
+    }
+    std::string line;
+    long matched = 0, missing = 0, cells = 0;
+    while (std::getline(in, line)) {
+        if (line.empty()) continue;
+        std::istringstream ss(line);
+        std::string name; int ntiles = 0;
+        ss >> name >> ntiles;
+        auto it = nameToNetId.find(name);
+        int netId = (it == nameToNetId.end()) ? -1 : it->second;
+        if (netId < 0) missing++;
+        else matched++;
+        std::string tok;
+        for (int k = 0; k < ntiles; k++) {
+            if (!(ss >> tok)) break;
+            auto comma = tok.find(',');
+            if (comma == std::string::npos) continue;
+            int row = std::stoi(tok.substr(0, comma));
+            int col = std::stoi(tok.substr(comma + 1));
+            if (netId >= 0) { netGuideTiles[netId].insert(tileKey(col, row)); cells++; }
+        }
+    }
+    log() << "GR guide loaded: " << matched << " nets matched, " << missing
+          << " unmatched, " << cells << " guide tiles, penalty=" << guidePenalty << std::endl;
+}
